conf-sr-policy.conf
# EOR for ipv4 sr-policy (AFI=1, SAFI=73)
1:cmd:announce eor ipv4 sr-policy
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:001E:02:00000007900F0003000149
# EOR for ipv6 sr-policy (AFI=2, SAFI=73)
1:cmd:announce eor ipv6 sr-policy
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:001E:02:00000007900F0003000249
# IPv4 SR Policy: MPLS preference + binding-sid + segment type-A (label 16001)
1:cmd:announce ipv4 sr-policy distinguisher 0 color 100 endpoint 10.0.0.1 next-hop 192.0.2.1 preference 100 binding-sid mpls 24000 segment-list weight 1 segment type-a mpls 16001
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF:0069:02:000000524001010040020040050400000064C01728000F00240C060000000000640D06100005DC01008000110009060000000000010106000003E81100800E1600014904C0000201006000000000000000640A000001
1:json:{"exabgp":"5.0.0","type":"update","neighbor":{"address":{"local":"127.0.0.1","peer":"127.0.0.1"},"asn":{"local":65533,"peer":65533},"router-id":"1.2.3.4","direction":"in","message":{"update":{"attribute":{"origin":"igp","local-preference":100,"tunnel-encap":{"sr-policy":{"preference":100,"binding-sid":{"type":"mpls","label":24000},"segment-lists":[{"weight":1,"segments":[{"type":"A","label":16001,"tc":0,"s":true,"ttl":0}]}]}}},"announce":{"ipv4 sr-policy":{"192.0.2.1":[{"distinguisher":0,"color":100,"endpoint":"10.0.0.1"}]}}}}}}
# IPv4 SR Policy: SRv6 binding-sid + type-B segment with endpoint-behavior + names
1:cmd:announce ipv4 sr-policy distinguisher 1 color 200 endpoint 10.0.0.2 next-hop 192.0.2.1 preference 200 srv6-binding-sid fc00::1 segment-list weight 2 segment type-b srv6 fc00::1 endpoint-behavior 65 32 0 16 0 policy-name "my-policy" candidate-path-name "primary"
